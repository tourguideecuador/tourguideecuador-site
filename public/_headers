# Netlify headers — shipped inside dist/ so they apply on drag-and-drop deploys too
# (netlify.toml only applies to git-connected builds). Mirrors netlify.toml.

# Fingerprinted, content-hashed assets (incl. self-hosted fonts) → cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Sensible security defaults for every route.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
