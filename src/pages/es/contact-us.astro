---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InquiryForm from '../../components/InquiryForm.astro';
import CredibilityStrip from '../../components/CredibilityStrip.astro';
import { SITE } from '../../lib/site';
---
<SiteLayout
  localized
  canonicalPath="/es/contact-us"
  title="Contacto — Tour Guide Ecuador"
  description="Contáctanos en Quito. Planifica tu crucero a Galápagos o tour por Ecuador por WhatsApp, correo o formulario — respondemos en un día hábil."
>
  <section class="border-b border-sand-300 bg-sand-50">
    <div class="container-page py-12 sm:py-16">
      <Breadcrumbs items={[{ name: 'Contacto', url: '/es/contact-us' }]} />
      <h1 class="mt-5 font-display text-[clamp(2.2rem,5vw,3.6rem)] font-medium">Planifiquemos tu viaje</h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-600">Cuéntanos tus fechas y qué te gustaría conocer. Te responderemos con ideas, disponibilidad y una cotización sin compromiso.</p>
    </div>
  </section>

  <CredibilityStrip />

  <section class="container-page grid gap-10 py-12 lg:grid-cols-[1fr_1.2fr] lg:items-start">
    <div class="space-y-6">
      <div class="rounded-2xl border border-sand-300 bg-white p-6 shadow-card">
        <h2 class="font-display text-xl">Escríbenos directamente</h2>
        <ul class="mt-4 space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-brand-500">✆</span>
            <span><span class="block font-medium text-ink-900">WhatsApp</span>
              <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="text-brand-600 hover:underline">{SITE.whatsappDisplay}</a></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-brand-500">✉</span>
            <span><span class="block font-medium text-ink-900">Correo</span>
              <a href={`mailto:${SITE.email}`} class="text-brand-600 hover:underline">{SITE.email}</a></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-brand-500">⌖</span>
            <span><span class="block font-medium text-ink-900">Oficina</span>{SITE.address}</span>
          </li>
        </ul>
      </div>
      <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="btn btn-primary w-full !py-4">Escríbenos por WhatsApp</a>
    </div>

    <div class="rounded-2xl border border-sand-300 bg-white p-6 shadow-card sm:p-8">
      <h2 class="font-display text-xl">Envíanos una consulta</h2>
      <p class="mt-1 text-sm text-ink-500">Respondemos en un día hábil.</p>
      <div class="mt-5"><InquiryForm subject="un viaje a medida por Ecuador / Galápagos" /></div>
    </div>
  </section>
</SiteLayout>
