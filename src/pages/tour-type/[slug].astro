---
import SiteLayout from '../../layouts/SiteLayout.astro';
import TourTypeDetail from '../../components/TourTypeDetail.astro';
import { getTourTypes, tourTypeUrl } from '../../lib/content';

export async function getStaticPaths() {
  const types = await getTourTypes();
  return types.map((type) => ({ params: { slug: type.data.slug }, props: { type } }));
}
const { type } = Astro.props;
const d = type.data;
---
<SiteLayout localized title={d.metaTitle} description={d.metaDescription} canonicalPath={tourTypeUrl(d.slug)}>
  <TourTypeDetail type={type} />
</SiteLayout>
