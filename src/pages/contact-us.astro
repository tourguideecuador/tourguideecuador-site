---
import SiteLayout from '../layouts/SiteLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import InquiryForm from '../components/InquiryForm.astro';
import CredibilityStrip from '../components/CredibilityStrip.astro';
import { SITE } from '../lib/site';
---
<SiteLayout
  localized
  title="Contact Us — Tour Guide Ecuador"
  description="Get in touch with Tour Guide Ecuador in Quito. Plan a Galápagos cruise or Ecuador tour by WhatsApp, email or enquiry form — we reply within one business day."
  canonicalPath="/contact-us"
>
  <section class="border-b border-sand-300 bg-sand-50">
    <div class="container-page py-12 sm:py-16">
      <Breadcrumbs items={[{ name: 'Contact Us', url: '/contact-us' }]} />
      <h1 class="mt-5 font-display text-[clamp(2.2rem,5vw,3.6rem)] font-medium">Let's plan your trip</h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-600">Tell us your dates and what you'd love to see. We'll reply with ideas, availability and a no-obligation quote.</p>
    </div>
  </section>

  <CredibilityStrip />

  <section class="container-page grid gap-10 py-12 lg:grid-cols-[1fr_1.2fr] lg:items-start">
    <div class="space-y-6">
      <div class="rounded-2xl border border-sand-300 bg-white p-6 shadow-card">
        <h2 class="font-display text-xl">Reach us directly</h2>
        <ul class="mt-4 space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-brand-500">✆</span>
            <span><span class="block font-medium text-ink-900">WhatsApp</span>
              <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="text-brand-600 hover:underline">{SITE.whatsappDisplay}</a></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-brand-500">✉</span>
            <span><span class="block font-medium text-ink-900">Email</span>
              <a href={`mailto:${SITE.email}`} class="text-brand-600 hover:underline">{SITE.email}</a></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-0.5 text-brand-500">⌖</span>
            <span><span class="block font-medium text-ink-900">Office</span>{SITE.address}</span>
          </li>
        </ul>
      </div>
      <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="btn btn-primary w-full !py-4">Chat on WhatsApp now</a>
    </div>

    <div class="rounded-2xl border border-sand-300 bg-white p-6 shadow-card sm:p-8">
      <h2 class="font-display text-xl">Send an enquiry</h2>
      <p class="mt-1 text-sm text-ink-500">We reply within one business day.</p>
      <div class="mt-5"><InquiryForm subject="a tailor-made Ecuador / Galápagos trip" /></div>
    </div>
  </section>
</SiteLayout>
