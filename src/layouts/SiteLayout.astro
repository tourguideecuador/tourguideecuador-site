---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Lightbox from '../components/Lightbox.astro';
import { getLangFromUrl } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalPath?: string;
  noindex?: boolean;
  overlayHeader?: boolean;
  localized?: boolean;
}
const { overlayHeader = false, localized = false, ...seo } = Astro.props;
// Show the language switcher only where a counterpart exists: ES pages always
// have an EN original; EN pages must opt in via `localized`.
const lang = getLangFromUrl(Astro.url);
const showLangSwitch = lang === 'es' || localized;
---
<BaseLayout {...seo} localized={localized}>
  <slot name="head" slot="head" />
  <a
    href="#main"
    class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-brand-600 focus:px-5 focus:py-2.5 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg"
  >{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>
  <Header overlay={overlayHeader} langSwitch={showLangSwitch} />
  <main id="main" class:list={[!overlayHeader && 'pt-[var(--header-h,4.75rem)]']}>
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
  <Lightbox />
</BaseLayout>
