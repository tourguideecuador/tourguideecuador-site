---
import { SITE, whatsappLink } from '../lib/site';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
interface Props { message?: string }
const t = useTranslations(getLangFromUrl(Astro.url));
const { message = t('wa.default') } = Astro.props;
---
<a
  href={whatsappLink(message)}
  target="_blank"
  rel="noopener"
  class="group fixed bottom-5 right-5 z-40 flex items-center gap-3 rounded-full bg-[#25D366] py-3 pl-3 pr-4 text-white shadow-lg shadow-black/20 transition-transform hover:scale-105 sm:bottom-6 sm:right-6"
  aria-label={`Chat on WhatsApp — ${SITE.whatsappDisplay}`}
>
  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.96L2 22l5.25-1.38a9.9 9.9 0 004.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91C21.95 6.45 17.5 2 12.04 2zm5.8 14.16c-.24.68-1.42 1.32-1.95 1.36-.5.04-1.13.21-3.81-.79-3.2-1.26-5.26-4.5-5.42-4.71-.16-.21-1.3-1.73-1.3-3.3 0-1.57.82-2.34 1.11-2.66.29-.32.63-.4.84-.4.21 0 .42 0 .6.01.2.01.46-.07.72.55.27.64.91 2.21.99 2.37.08.16.13.35.03.56-.1.21-.16.34-.32.53-.16.18-.34.41-.48.55-.16.16-.33.34-.14.66.19.32.84 1.39 1.81 2.25 1.25 1.11 2.3 1.46 2.62 1.62.32.16.51.13.7-.08.19-.21.81-.94 1.02-1.27.21-.32.43-.27.72-.16.29.11 1.85.87 2.17 1.03.32.16.53.24.61.37.08.13.08.76-.16 1.44z"/>
  </svg>
  <span class="max-w-0 overflow-hidden whitespace-nowrap text-sm font-semibold opacity-0 transition-all duration-300 group-hover:max-w-[10rem] group-hover:opacity-100">
    Chat with us
  </span>
</a>
