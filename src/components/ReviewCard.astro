---
import Stars from './Stars.astro';
import { render } from 'astro:content';
import type { Review } from '../lib/content';
interface Props { review: Review; class?: string }
const { review, class: cls = '' } = Astro.props;
const { Content } = await render(review);
const initials = review.data.author.split(' ').map((w) => w[0]).slice(0, 2).join('');
---
<figure class={`flex h-full flex-col rounded-2xl border border-sand-300 bg-white p-6 shadow-card ${cls}`}>
  <Stars rating={review.data.rating} />
  <blockquote class="prose-tge mt-4 flex-1 text-[0.98rem] leading-relaxed text-ink-700">
    <Content />
  </blockquote>
  <figcaption class="mt-5 flex items-center gap-3 border-t border-sand-200 pt-4">
    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 text-sm font-bold text-brand-700">{initials}</span>
    <span>
      <span class="block text-sm font-semibold text-ink-900">{review.data.author}</span>
      {review.data.location && <span class="block text-xs text-ink-500">{review.data.location}</span>}
    </span>
  </figcaption>
</figure>
