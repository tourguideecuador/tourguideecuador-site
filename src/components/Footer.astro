---
import Logo from './Logo.astro';
import NewsletterSignup from './NewsletterSignup.astro';
import { SITE } from '../lib/site';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (href: string) => localizePath(href, lang);
const es = lang === 'es';
const year = 2026;
const cols = [
  { title: t('footer.galapagos'), links: [
    { label: es ? 'Todos los cruceros' : 'All cruises', href: '/cruises' },
    { label: 'Island hopping', href: '/island-hopping-home' },
    { label: es ? 'Buceo' : 'Diving', href: '/diving' },
    { label: 'Galápagos & Machu Picchu', href: '/galapagos-machu-picchu' },
  ]},
  { title: t('footer.tours'), links: [
    { label: es ? 'Todos los tours' : 'All day tours', href: '/tours' },
    { label: es ? 'City Tour de Quito' : 'Quito City Tour', href: '/tours/quito-city-tour' },
    { label: 'Cotopaxi', href: '/tours/cotopaxi' },
    { label: es ? 'Mercado de Otavalo' : 'Otavalo Market', href: '/tours/otavalo-market' },
  ]},
  { title: t('footer.company'), links: [
    { label: t('nav.about'), href: '/about-us' },
    { label: t('nav.reviews'), href: '/reviews' },
    { label: t('nav.whenToGo'), href: '/galapagos-wildlife-calendar' },
    { label: t('nav.faq'), href: '/faqs' },
    { label: es ? 'Contacto' : 'Contact', href: '/contact-us' },
  ]},
];
---
<footer class="mt-24 bg-ink-900 text-sand-200">
  <div class="container-page grid gap-12 py-16 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div>
      <Logo />
      <p class="mt-5 max-w-xs text-sm leading-relaxed text-ink-300">
        {es
          ? 'Agencia de viajes en Quito que crea cruceros a Galápagos y viajes a medida por todo el Ecuador, desde que las islas nos cautivaron.'
          : 'A Quito-based travel agency crafting Galápagos cruises and tailor-made journeys across Ecuador since the islands first cast their spell.'}
      </p>
      <a href={SITE.whatsappHref} target="_blank" rel="noopener"
         class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-brand-300 hover:text-brand-200">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.96L2 22l5.25-1.38a9.9 9.9 0 004.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91C21.95 6.45 17.5 2 12.04 2zm5.8 14.16c-.24.68-1.42 1.32-1.95 1.36-.5.04-1.13.21-3.81-.79-3.2-1.26-5.26-4.5-5.42-4.71-.16-.21-1.3-1.73-1.3-3.3 0-1.57.82-2.34 1.11-2.66.29-.32.63-.4.84-.4.21 0 .42 0 .6.01.2.01.46-.07.72.55.27.64.91 2.21.99 2.37.08.16.13.35.03.56-.1.21-.16.34-.32.53-.16.18-.34.41-.48.55-.16.16-.33.34-.14.66.19.32.84 1.39 1.81 2.25 1.25 1.11 2.3 1.46 2.62 1.62.32.16.51.13.7-.08.19-.21.81-.94 1.02-1.27.21-.32.43-.27.72-.16.29.11 1.85.87 2.17 1.03.32.16.53.24.61.37.08.13.08.76-.16 1.44z"/></svg>
        {SITE.whatsappDisplay}
      </a>
      <NewsletterSignup class="mt-7 max-w-xs" />
    </div>
    {cols.map((col) => (
      <nav aria-label={col.title}>
        <p class="font-sans text-xs font-bold uppercase tracking-[0.18em] text-ink-300">{col.title}</p>
        <ul class="mt-4 space-y-2.5 text-sm">
          {col.links.map((l) => (
            <li><a href={L(l.href)} class="text-sand-200/90 transition-colors hover:text-brand-300">{l.label}</a></li>
          ))}
        </ul>
      </nav>
    ))}
  </div>
  <div class="border-t border-white/10">
    <div class="container-page flex flex-col items-center justify-between gap-3 py-6 text-xs text-ink-300 sm:flex-row">
      <p>© {year} {SITE.name}. {SITE.address}.{SITE.licenseNumber && ` MINTUR ${SITE.licenseNumber}.`}</p>
      <p class="flex items-center gap-2">
        <span class="text-brand-400">★</span> {SITE.nytQuote}
      </p>
    </div>
  </div>
</footer>
