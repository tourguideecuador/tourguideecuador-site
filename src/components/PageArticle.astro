---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import Breadcrumbs from './Breadcrumbs.astro';
import UntranslatedNotice from './UntranslatedNotice.astro';
import { SITE } from '../lib/site';
import { getLangFromUrl } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';
interface Props { page: CollectionEntry<'pages'> }
const { page } = Astro.props;
const d = page.data;
const { Content } = await render(page);
const overviewLabel = getLangFromUrl(Astro.url) === 'es' ? 'Contenido de la página' : 'Page content';
---
<UntranslatedNotice />

<section class="border-b border-sand-300 bg-sand-50">
  <div class="container-page py-12 sm:py-16">
    <Breadcrumbs items={[{ name: d.title, url: `/${d.slug}` }]} />
    <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.2rem,5vw,3.6rem)] font-medium">{d.title}</h1>
  </div>
</section>

{d.heroImage && (
  <div class="container-page -mt-2 pt-8">
    <Image src={d.heroImage} alt={d.heroImageAlt ?? d.title} width={1200} height={600} class="aspect-[2/1] w-full rounded-2xl object-cover" loading="eager" fetchpriority="high" />
  </div>
)}

<div class="container-page py-12">
  <article class="prose-tge mx-auto max-w-2xl"><h2 class="sr-only">{overviewLabel}</h2><Content /></article>
  <div class="mx-auto mt-12 max-w-2xl rounded-2xl border border-sand-300 bg-white p-6 text-center shadow-card">
    <h2 class="font-display text-xl">Questions? We're here to help.</h2>
    <p class="mt-2 text-sm text-ink-600">Message us on WhatsApp or send an enquiry — we reply fast.</p>
    <div class="mt-4 flex flex-wrap justify-center gap-3">
      <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="btn btn-primary">Chat on WhatsApp</a>
      <a href="/contact-us" class="btn btn-outline">Contact us</a>
    </div>
  </div>
</div>
