---
interface Props { rating?: number; class?: string }
const { rating = 5, class: cls = '' } = Astro.props;
---
<span class={`inline-flex items-center gap-0.5 text-brand-500 ${cls}`} role="img" aria-label={`${rating} out of 5 stars`}>
  {Array.from({ length: 5 }).map((_, i) => (
    <svg width="16" height="16" viewBox="0 0 24 24" fill={i < Math.round(rating) ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M12 2.5l2.9 6.06 6.6.86-4.85 4.55 1.24 6.58L12 17.9l-5.89 3.21 1.24-6.58L2.5 9.42l6.6-.86z"/>
    </svg>
  ))}
</span>
