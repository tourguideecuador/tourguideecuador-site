---
// Global lightbox overlay. Any element with [data-lb] (carrying data-lb-group,
// data-lb-full, data-lb-alt) opens it. Uses a native <dialog> for focus-trap +
// Esc. Click delegation = survives View-Transition navigations.
---
<dialog id="lightbox" class="lb" aria-label="Image viewer">
  <button type="button" data-lb-close class="lb-btn lb-close" aria-label="Close (Esc)">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
  </button>
  <button type="button" data-lb-prev class="lb-btn lb-prev" aria-label="Previous image">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <figure class="lb-fig">
    <img id="lb-img" alt="" />
    <figcaption id="lb-counter" class="lb-counter"></figcaption>
  </figure>
  <button type="button" data-lb-next class="lb-btn lb-next" aria-label="Next image">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
  </button>
</dialog>

<style>
  .lb { width: min(96vw, 1400px); max-width: none; max-height: 96vh; border: 0; background: transparent; padding: 0; color: #fff; overflow: visible; }
  .lb::backdrop { background: rgba(12, 10, 8, 0.92); backdrop-filter: blur(4px); }
  .lb[open] { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 0.5rem; }
  .lb-fig { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
  #lb-img { max-width: 100%; max-height: 86vh; border-radius: 0.5rem; box-shadow: 0 24px 60px -20px rgba(0,0,0,0.7); animation: lb-in 0.3s cubic-bezier(0.16,1,0.3,1); }
  @keyframes lb-in { from { opacity: 0; transform: scale(0.97); } }
  .lb-counter { font-size: 0.85rem; color: rgba(255,255,255,0.7); }
  .lb-btn { display: inline-flex; align-items: center; justify-content: center; height: 3rem; width: 3rem; border-radius: 999px; background: rgba(255,255,255,0.12); color: #fff; transition: background 0.15s ease, transform 0.15s ease; cursor: pointer; }
  .lb-btn:hover { background: rgba(255,255,255,0.24); }
  .lb-close { position: fixed; top: 1rem; right: 1rem; }
  @media (max-width: 640px) {
    .lb[open] { grid-template-columns: 1fr; }
    .lb-prev, .lb-next { position: fixed; top: 50%; transform: translateY(-50%); z-index: 2; }
    .lb-prev { left: 0.5rem; } .lb-next { right: 0.5rem; }
  }
  @media (prefers-reduced-motion: reduce) { #lb-img { animation: none; } }
</style>

<script>
  // Delegated, module-scope handlers: bound once, and every element is looked up
  // fresh per event so the lightbox keeps working after View-Transitions swaps
  // (closure-captured nodes would go stale when the DOM is replaced).
  let group: HTMLElement[] = [];
  let idx = 0;
  const dlgEl = () => document.getElementById('lightbox') as HTMLDialogElement | null;

  const showAt = (i: number) => {
    const dlg = dlgEl();
    const img = document.getElementById('lb-img') as HTMLImageElement | null;
    const counter = document.getElementById('lb-counter');
    if (!dlg || !img || group.length === 0) return;
    idx = (i + group.length) % group.length;
    const el = group[idx];
    img.src = el.dataset.lbFull || '';
    img.alt = el.dataset.lbAlt || '';
    if (counter) counter.textContent = group.length > 1 ? `${idx + 1} / ${group.length}` : '';
    // preload neighbours
    [idx + 1, idx - 1].forEach((n) => {
      const src = group[(n + group.length) % group.length]?.dataset.lbFull;
      if (src) { const p = new Image(); p.src = src; }
    });
  };
  const open = (trigger: HTMLElement) => {
    const dlg = dlgEl();
    if (!dlg) return;
    const g = trigger.dataset.lbGroup || 'default';
    group = [...document.querySelectorAll<HTMLElement>(`[data-lb][data-lb-group="${g}"]`)];
    showAt(group.indexOf(trigger));
    if (!dlg.open) dlg.showModal();
  };

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const trigger = target?.closest<HTMLElement>('[data-lb]');
    if (trigger) { e.preventDefault(); open(trigger); return; }
    const dlg = dlgEl();
    if (!dlg?.open) return;
    if (target.closest('[data-lb-next]')) showAt(idx + 1);
    else if (target.closest('[data-lb-prev]')) showAt(idx - 1);
    else if (target.closest('[data-lb-close]') || e.target === dlg) dlg.close(); // incl. backdrop
  });
  document.addEventListener('keydown', (e) => {
    if (!dlgEl()?.open) return;
    if (e.key === 'ArrowRight') showAt(idx + 1);
    if (e.key === 'ArrowLeft') showAt(idx - 1);
  });
  // swipe
  let sx = 0;
  document.addEventListener('touchstart', (e) => { if (dlgEl()?.open) sx = e.touches[0].clientX; }, { passive: true });
  document.addEventListener('touchend', (e) => {
    const dlg = dlgEl();
    if (!dlg?.open) return;
    const dx = e.changedTouches[0].clientX - sx;
    if (Math.abs(dx) > 50) showAt(idx + (dx < 0 ? 1 : -1));
  }, { passive: true });
</script>
