---
import { Image } from 'astro:assets';
import { cruiseUrl } from '../lib/content';
import type { Cruise } from '../lib/content';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';
interface Props { cruise: Cruise; class?: string; featured?: boolean }
const { cruise, class: cls = '', featured = false } = Astro.props;
const { title, heroImage, heroImageAlt, excerpt, vesselClass, vesselType } = cruise.data;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const href = localizePath(cruiseUrl(cruise.data.slug), lang);
---
<a href={href} class={`card card-link group relative flex flex-col ${cls}`}>
  <div class={`relative overflow-hidden ${featured ? 'aspect-[4/5]' : 'aspect-[3/2]'}`}>
    <Image src={heroImage} alt={heroImageAlt ?? title} width={featured ? 760 : 640} height={featured ? 950 : 430}
      transition:name={`cruise-img-${cruise.data.slug}`}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink-950/80 via-ink-950/10 to-transparent"></div>
    {vesselClass && (
      <span class="glass absolute left-4 top-4 rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-ink-900 shadow-sm">{vesselClass}</span>
    )}
    <div class="absolute inset-x-0 bottom-0 p-5 text-white">
      <p class="text-[0.7rem] font-medium uppercase tracking-[0.16em] text-white/75">{vesselType ?? 'Galápagos cruise'}</p>
      <h3 class="mt-1 font-display text-2xl leading-tight text-white">{title}</h3>
      {featured && <p class="mt-2 line-clamp-2 max-w-sm text-sm text-white/85">{excerpt}</p>}
      <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-300">
        {t('cta.viewCruise')} <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </span>
    </div>
  </div>
</a>
