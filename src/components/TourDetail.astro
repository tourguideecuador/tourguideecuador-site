---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import Breadcrumbs from './Breadcrumbs.astro';
import BokunWidget from './BokunWidget.astro';
import Gallery from './Gallery.astro';
import TourCard from './TourCard.astro';
import UntranslatedNotice from './UntranslatedNotice.astro';
import JsonLd from './JsonLd.astro';
import { getTours, destinationName, tourTypeName, tourUrl, destinationUrl } from '../lib/content';
import { productSchema } from '../lib/schema';
import { SITE } from '../lib/site';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';
import type { Tour } from '../lib/content';

interface Props { tour: Tour }
const { tour } = Astro.props;
const d = tour.data;
const lang = getLangFromUrl(Astro.url);
const es = lang === 'es';
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
const { Content } = await render(tour);
const dest = await destinationName(d.destination.id);
const type = await tourTypeName(d.type.id);
const allTours = await getTours();
const related = allTours.filter((x) => x.data.destination.id === d.destination.id && x.id !== tour.id).slice(0, 4);
const canonical = L(tourUrl(d.slug));
const tr = {
  tours: t('nav.tours'),
  gallery: es ? 'Galería' : 'Gallery',
  pricing: es ? 'Precio' : 'Pricing',
  from: t('label.from'),
  onRequest: t('label.onRequest'),
  ask: es ? 'Pregunta por WhatsApp' : 'Ask a question on WhatsApp',
  moreIn: es ? `Más en ${dest}` : `More in ${dest}`,
  overview: es ? 'Resumen del tour' : 'Tour overview',
};
const facts = [
  d.durationLabel && { label: es ? 'Duración' : 'Duration', value: d.durationLabel },
  { label: es ? 'Destino' : 'Destination', value: dest },
  { label: es ? 'Tipo' : 'Type', value: type },
  { label: es ? 'Salida desde' : 'Departs from', value: es ? 'Quito (o tu hotel)' : 'Quito (or your hotel)' },
].filter(Boolean) as { label: string; value: string }[];
---
<JsonLd slot="head" schema={productSchema({ name: d.title, description: d.metaDescription, url: `${SITE.url}${canonical}`, priceFrom: d.priceFrom })} />

<section class="relative isolate overflow-hidden bg-ink-900">
  <Image src={d.heroImage} alt={d.heroImageAlt ?? d.title} widths={[768, 1280, 1800]} sizes="100vw" transition:name={`tour-img-${d.slug}`} class="absolute inset-0 h-full w-full object-cover opacity-70" loading="eager" />
  <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/40 to-ink-950/30"></div>
  <div class="container-page relative py-16 text-white sm:py-24">
    <div class="[&_*]:!text-white/80"><Breadcrumbs items={[{ name: tr.tours, url: L('/tours') }, { name: dest, url: L(destinationUrl(d.destination.id)) }, { name: d.title, url: canonical }]} /></div>
    <p class="eyebrow mt-6 text-brand-300">{type}</p>
    <h1 class="mt-3 max-w-3xl font-display text-[clamp(2.2rem,5vw,3.6rem)] font-medium text-white">{d.title}</h1>
    <p class="mt-4 max-w-2xl text-lg text-white/85">{d.excerpt}</p>
  </div>
</section>

<UntranslatedNotice />

<div class="container-page grid gap-12 py-14 lg:grid-cols-[1fr_22rem]">
  <div>
    <div class="prose-tge max-w-2xl"><h2 class="sr-only">{tr.overview}</h2><Content /></div>
    {d.gallery.length > 0 && (
      <div class="mt-12">
        <h2 class="font-display text-2xl">{tr.gallery}</h2>
        <Gallery images={d.gallery} group={`tour-${d.slug}`} alt={d.title} class="mt-5" />
      </div>
    )}
  </div>

  <aside class="lg:sticky lg:top-[calc(var(--header-h,4.75rem)+1.5rem)] lg:self-start">
    <div class="rounded-2xl border border-sand-300 bg-white p-5 shadow-card">
      <div class="flex items-baseline justify-between">
        <span class="text-sm text-ink-500">{d.priceFrom ? tr.from : tr.pricing}</span>
        <span class="font-display text-2xl text-ink-900">{d.priceFrom ? `$${d.priceFrom}` : tr.onRequest}</span>
      </div>
      <hr class="rule my-4" />
      <BokunWidget experienceId={d.bokunExperienceId} title={d.title} />
      <dl class="mt-5 space-y-3 text-sm">
        {facts.map((f) => (
          <div class="flex justify-between gap-4 border-b border-sand-200 pb-2 last:border-0">
            <dt class="text-ink-500">{f.label}</dt>
            <dd class="text-right font-medium text-ink-900">{f.value}</dd>
          </div>
        ))}
      </dl>
    </div>
    <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="btn btn-outline mt-3 w-full">{tr.ask}</a>
  </aside>
</div>

{related.length > 0 && (
  <section class="border-t border-sand-300 bg-sand-50 py-16">
    <div class="container-page">
      <h2 class="font-display text-2xl">{tr.moreIn}</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {related.map((x) => <TourCard tour={x} />)}
      </div>
    </div>
  </section>
)}
