---
import { SITE } from '../lib/site';
import { getLangFromUrl, localizePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const es = lang === 'es';
const L = (p: string) => localizePath(p, lang);
const tr = {
  title: es ? '¡Gracias!' : 'Thank you!',
  text: es
    ? 'Tu consulta va camino a nuestro equipo en Quito. Te responderemos en un día hábil, normalmente mucho antes.'
    : "Your enquiry is on its way to our team in Quito. We'll reply within one business day — usually much sooner.",
  wa: es ? 'Escríbenos por WhatsApp' : 'Message us on WhatsApp',
  home: es ? 'Volver al inicio' : 'Back to home',
  guideTitle: es ? '¡Tu guía va en camino!' : 'Your guide is on its way!',
  guideText: es
    ? '¡Gracias! Te enviaremos por correo tu guía de cruceros por Galápagos en breve — revisa tu bandeja de entrada (y el spam, por si acaso). También puedes descargarla aquí:'
    : "Thanks! We'll email your Galápagos cruise guide shortly — check your inbox (and spam, just in case). You can also download it here:",
  download: es ? 'Descargar la guía (PDF)' : 'Download the guide (PDF)',
};
const GUIDE_PDF = '/downloads/galapagos-cruise-guide.pdf';
---
<section class="container-page flex min-h-[60svh] flex-col items-center justify-center py-24 text-center">
  <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-100 text-3xl text-brand-600">✓</span>
  <h1 id="ty-title" class="mt-6 font-display text-4xl">{tr.title}</h1>
  <p id="ty-text" class="mt-3 max-w-md text-lg text-ink-600">{tr.text}</p>
  <div class="mt-8 flex flex-wrap justify-center gap-3">
    <a id="ty-download" href={GUIDE_PDF} download hidden class="btn btn-primary">{tr.download}</a>
    <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="btn btn-primary">{tr.wa}</a>
    <a href={L('/')} class="btn btn-outline">{tr.home}</a>
  </div>
</section>
<script is:inline define:vars={{ guideTitle: tr.guideTitle, guideText: tr.guideText }}>
  if (new URLSearchParams(location.search).get('guide')) {
    const t = document.getElementById('ty-title');
    const p = document.getElementById('ty-text');
    const d = document.getElementById('ty-download');
    if (t) t.textContent = guideTitle;
    if (p) p.textContent = guideText;
    if (d) d.hidden = false;
  }
</script>
