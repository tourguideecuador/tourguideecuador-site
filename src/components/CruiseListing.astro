---
import Breadcrumbs from './Breadcrumbs.astro';
import CruiseCard from './CruiseCard.astro';
import LeadMagnet from './LeadMagnet.astro';
import { getCruises } from '../lib/content';
import { getLangFromUrl, localizePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const es = lang === 'es';
const L = (p: string) => localizePath(p, lang);
const cruises = await getCruises();
const order = ['Luxury', 'First Class', 'Tourist Superior', 'Tourist', 'Diving'];
const classes = order.filter((c) => cruises.some((cr) => cr.data.vesselClass === c));
const tr = {
  crumb: es ? 'Cruceros Galápagos' : 'Galápagos Cruises',
  eyebrow: es ? 'Las Islas Encantadas' : 'The Enchanted Islands',
  h1: es ? 'Cruceros a Galápagos' : 'Galápagos cruises',
  intro: es
    ? 'Trece embarcaciones cuidadosamente seleccionadas — desde íntimos catamaranes de lujo hasta barcos de expedición y de buceo. Te ayudamos a elegir el barco, la ruta y las fechas, con el mejor precio disponible.'
    : "Thirteen hand-picked vessels — from intimate luxury catamarans to expedition ships and dive liveaboards. We'll match you to the right boat, route and dates, and quote the best available price.",
  compare: es ? 'Comparar embarcaciones' : 'Compare vessels side by side',
  whenToGo: es ? 'Cuándo ir →' : 'When to go →',
  all: es ? 'Todas' : 'All',
  sort: es ? 'Ordenar' : 'Sort',
  featured: es ? 'Destacados' : 'Featured',
  az: es ? 'Nombre A–Z' : 'Name A–Z',
  byClass: es ? 'Por categoría' : 'By class',
};
---
<section class="border-b border-sand-300 bg-ink-900 text-sand-100">
  <div class="container-page py-14 sm:py-20">
    <div class="[&_*]:!text-sand-200/70"><Breadcrumbs items={[{ name: tr.crumb, url: L('/cruises') }]} /></div>
    <p class="eyebrow mt-6 text-brand-300">{tr.eyebrow}</p>
    <h1 class="mt-3 max-w-3xl font-display text-[clamp(2.2rem,5vw,3.8rem)] font-medium text-white">{tr.h1}</h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-300">{tr.intro}</p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={L('/cruises/compare')} class="btn btn-primary">{tr.compare}</a>
      <a href={L('/galapagos-wildlife-calendar')} class="btn btn-ghost !border-white/40">{tr.whenToGo}</a>
    </div>
  </div>
</section>

<section class="container-page py-10">
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex flex-wrap gap-2" role="group" aria-label="Filter cruises by class">
      <button type="button" data-filter="all" class="filter-chip is-active">{tr.all} ({cruises.length})</button>
      {classes.map((c) => <button type="button" data-filter={c} class="filter-chip">{c}</button>)}
    </div>
    <label class="ml-auto text-sm text-ink-600">{tr.sort}
      <select id="sort-cruises" class="form-input ml-2 inline-block w-auto !py-1.5 text-sm">
        <option value="featured">{tr.featured}</option>
        <option value="az">{tr.az}</option>
        <option value="class">{tr.byClass}</option>
      </select>
    </label>
  </div>
  <div id="cruise-grid" class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {cruises.map((c, i) => (
      <div data-class={c.data.vesselClass} data-order={i} data-name={c.data.title}><CruiseCard cruise={c} /></div>
    ))}
  </div>
</section>

<LeadMagnet class="mt-6" />

<style>
  .filter-chip { border-radius: 999px; border: 1.5px solid var(--color-sand-300); padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 600; color: var(--color-ink-600); transition: all 0.15s ease; cursor: pointer; }
  .filter-chip:hover { border-color: var(--color-brand-400); color: var(--color-brand-600); }
  .filter-chip.is-active { background: var(--color-ink-900); border-color: var(--color-ink-900); color: var(--color-sand-100); }
</style>
<script>
  function initCruiseFilter() {
    const grid = document.getElementById('cruise-grid');
    if (!grid) return;
    const chips = [...document.querySelectorAll<HTMLButtonElement>('.filter-chip')];
    const cards = [...grid.querySelectorAll<HTMLElement>('[data-class]')];
    const sortSel = document.getElementById('sort-cruises') as HTMLSelectElement;
    const order = ['Luxury', 'First Class', 'Tourist Superior', 'Tourist', 'Diving'];
    let filter = 'all';
    function apply() {
      cards.forEach((c) => { c.hidden = !(filter === 'all' || c.dataset.class === filter); });
      const sorted = [...cards].sort((a, b) => {
        if (sortSel?.value === 'az') return (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '');
        if (sortSel?.value === 'class') return order.indexOf(a.dataset.class ?? '') - order.indexOf(b.dataset.class ?? '');
        return Number(a.dataset.order) - Number(b.dataset.order);
      });
      sorted.forEach((c) => grid!.appendChild(c));
    }
    chips.forEach((chip) => chip.addEventListener('click', () => {
      filter = chip.dataset.filter!;
      chips.forEach((c) => c.classList.toggle('is-active', c === chip));
      apply();
    }));
    sortSel?.addEventListener('change', apply);
    apply();
  }
  document.addEventListener('astro:page-load', initCruiseFilter);
</script>
