---
import { SITE } from '../lib/site';
/*
  Bókun day-tour booking widget shell.
  Real bookings render once the client supplies each experience's Bókun ID
  (frontmatter `bokunExperienceId`) and the channel UUID (PUBLIC_BOKUN_CHANNEL_ID).
  Until then we show a clean "request to book" placeholder so the page is complete.
*/
interface Props { experienceId?: string; title?: string }
const { experienceId, title = 'this tour' } = Astro.props;
const channelId = import.meta.env.PUBLIC_BOKUN_CHANNEL_ID;
const ready = Boolean(experienceId && channelId);
const bookText = `Hi! I'd like to book ${title}.`;
---
{ready ? (
  <>
    <script async src={`https://widgets.bokun.io/assets/javascripts/apps/build/BokunWidgetsLoader.js?bookingChannelUUID=${channelId}`} is:inline></script>
    <div
      class="bokunWidget rounded-2xl border border-sand-300 bg-white p-1"
      data-src={`https://widgets.bokun.io/online-sales/${channelId}/experience/${experienceId}`}
    ></div>
    <noscript><a class="btn btn-primary w-full" href={`https://wa.me/${SITE.whatsappNumber}`}>Enquire to book</a></noscript>
  </>
) : (
  <div class="rounded-2xl border border-dashed border-brand-300 bg-brand-50/60 p-6 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">Online booking opening soon</p>
    <p class="mt-2 text-sm text-ink-600">
      Live availability &amp; instant booking for {title} are being set up. For now, reserve in
      minutes — we reply fast.
    </p>
    <a href={`https://wa.me/${SITE.whatsappNumber}?text=${encodeURIComponent(bookText)}`}
       target="_blank" rel="noopener" class="btn btn-primary mt-4 w-full">Request to book</a>
    <a href="/contact-us" class="mt-2 inline-block text-sm font-medium text-brand-600 hover:underline">or send an enquiry →</a>
  </div>
)}
