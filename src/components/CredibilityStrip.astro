---
import Stars from './Stars.astro';
import { SITE } from '../lib/site';
import { aggregateRating } from '../lib/content';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

interface Props { variant?: 'sand' | 'dark'; class?: string }
const { variant = 'sand', class: cls = '' } = Astro.props;
const rating = await aggregateRating();
const t = useTranslations(getLangFromUrl(Astro.url));

const dark = variant === 'dark';
const wrap = dark ? 'bg-ink-900 text-sand-100 border-y border-white/10' : 'bg-sand-50 text-ink-700 border-y border-sand-300';
const sep = dark ? 'bg-white/15' : 'bg-sand-300';
const strong = dark ? 'text-white' : 'text-ink-900';
---
<section class={`${wrap} ${cls}`} aria-label="Why book with us">
  <div class="container-page flex flex-wrap items-center justify-center gap-x-8 gap-y-3 py-4 text-sm">
    <!-- rating -->
    {rating.count > 0 && (
      <span class="flex items-center gap-2">
        <Stars rating={rating.value} />
        <span><strong class={strong}>{rating.value.toFixed(1)}</strong> · {rating.count} {t('trust.reviews')}</span>
      </span>
    )}
    <span class={`hidden h-4 w-px sm:block ${sep}`}></span>
    <!-- NYT -->
    <span class="flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-brand-500"><path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z"/></svg>
      {t('trust.nyt')}
    </span>
    <!-- MINTUR licence (only if set in settings) -->
    {SITE.licenseNumber && (<>
      <span class={`hidden h-4 w-px sm:block ${sep}`}></span>
      <span class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-brand-500"><path d="M9 12l2 2 4-4M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/></svg>
        {t('trust.licensed')}&nbsp;{SITE.licenseNumber}
      </span>
    </>)}
    <span class={`hidden h-4 w-px sm:block ${sep}`}></span>
    <!-- secure booking -->
    <span class="flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-brand-500"><rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
      {t('trust.secure')}
    </span>
    <span class={`hidden h-4 w-px sm:block ${sep}`}></span>
    <!-- local guides -->
    <span class="flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-brand-500"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6"/></svg>
      {t('trust.local')}
    </span>
  </div>
</section>
