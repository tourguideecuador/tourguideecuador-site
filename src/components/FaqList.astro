---
import { getCollection, render } from 'astro:content';
import Breadcrumbs from './Breadcrumbs.astro';
import { SITE } from '../lib/site';
import { getLangFromUrl, localizePath } from '../i18n/ui';
import { faqsEs, categoriesEs } from '../data/faqs-es';

const lang = getLangFromUrl(Astro.url);
const es = lang === 'es';
const L = (p: string) => localizePath(p, lang);

const categoriesEn = [
  { key: 'cruises', label: 'Galápagos cruises' },
  { key: 'tours', label: 'Ecuador tours' },
  { key: 'booking', label: 'Booking & payment' },
  { key: 'practical', label: 'Travel & practical' },
] as const;

// Normalise EN (MDX collection) and ES (data module) to one render shape.
type Item = { question: string; category: string; Content?: any; html?: string };
let categories: { key: string; label: string }[];
let items: Item[];
if (es) {
  categories = categoriesEs;
  items = [...faqsEs]
    .sort((a, b) => a.order - b.order)
    .map((f) => ({ question: f.question, category: f.category, html: f.answerHtml }));
} else {
  categories = categoriesEn as unknown as { key: string; label: string }[];
  const faqs = (await getCollection('faqs')).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
  items = await Promise.all(
    faqs.map(async (f) => ({ question: f.data.question, category: f.data.category, Content: (await render(f)).Content })),
  );
}

const tr = {
  crumb: 'FAQ',
  h1: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  lede1: es
    ? 'Todo lo que los viajeros suelen preguntar sobre cruceros a Galápagos y tours por Ecuador. ¿No lo encuentras? '
    : "Everything travellers usually ask about Galápagos cruises and Ecuador tours. Can't find it? ",
  ledeLink: es ? 'Pregúntanos por WhatsApp' : 'Just ask us on WhatsApp',
  stillTitle: es ? '¿Aún tienes una pregunta?' : 'Still have a question?',
  stillLede: es ? 'Estamos a un mensaje de distancia y encantados de ayudarte a planear.' : "We're a quick message away — and happy to help you plan.",
  plan: es ? 'Planea tu viaje' : 'Plan my trip',
  wa: es ? 'Escríbenos por WhatsApp' : 'WhatsApp us',
};
---
<section class="border-b border-sand-300 bg-sand-50">
  <div class="container-page py-12 sm:py-16">
    <Breadcrumbs items={[{ name: tr.crumb, url: L('/faqs') }]} />
    <h1 class="mt-5 max-w-3xl font-display text-[clamp(2.2rem,5vw,3.6rem)] font-medium">{tr.h1}</h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-600">{tr.lede1}<a class="font-medium text-brand-600 hover:underline" href={SITE.whatsappHref}>{tr.ledeLink}</a>.</p>
  </div>
</section>

<section class="container-page py-12">
  <div class="mx-auto max-w-3xl space-y-12">
    {categories.map((cat) => {
      const catItems = items.filter((r) => r.category === cat.key);
      if (!catItems.length) return null;
      return (
        <div>
          <h2 class="font-display text-2xl text-ink-900">{cat.label}</h2>
          <div class="mt-4 divide-y divide-sand-300 rounded-2xl border border-sand-300 bg-white shadow-card">
            {catItems.map((it) => (
              <details class="faq group">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-medium text-ink-900">
                  <span>{it.question}</span>
                  <svg class="shrink-0 text-brand-500 transition-transform duration-200 group-open:rotate-45" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                </summary>
                <div class="prose-tge px-5 pb-5 text-[0.97rem] text-ink-700">
                  {it.Content ? <it.Content /> : <p set:html={it.html} />}
                </div>
              </details>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<section class="border-t border-sand-300 bg-sand-200/50 py-14">
  <div class="container-page text-center">
    <h2 class="font-display text-2xl">{tr.stillTitle}</h2>
    <p class="mt-2 text-ink-600">{tr.stillLede}</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href={L('/plan-my-trip')} class="btn btn-primary">{tr.plan}</a>
      <a href={SITE.whatsappHref} target="_blank" rel="noopener" class="btn btn-outline">{tr.wa}</a>
    </div>
  </div>
</section>

<style>
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary:hover { background: var(--color-sand-50); }
  .faq[open] summary { color: var(--color-brand-700); }
</style>
