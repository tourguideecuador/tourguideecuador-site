# Tour Guide Ecuador — environment variables. Copy to .env (.env is git-ignored).

# WhatsApp floating button. Digits only, country code first.
PUBLIC_WHATSAPP_NUMBER=593991946532

# Cloudflare Turnstile (form spam protection).
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Bokun day-tour booking widget (public embed).
PUBLIC_BOKUN_CHANNEL_ID=

# Keystatic Cloud project — enables content editing on the deployed site.
PUBLIC_KEYSTATIC_CLOUD_PROJECT=
